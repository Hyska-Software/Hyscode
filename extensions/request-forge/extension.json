{
  "name": "request-forge",
  "displayName": "Request Forge (BETA)",
  "version": "1.0.0",
  "description": "Cliente HTTP completo para a IDE — envie requisições REST/GraphQL, gerencie ambientes, visualize respostas formatadas e salve histórico diretamente nos arquivos .http",
  "publisher": "hyscode",
  "engines": {
    "hyscode": ">=0.1.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "http",
    "rest",
    "api",
    "client",
    "request",
    "graphql",
    "curl",
    "fetch",
    "endpoint"
  ],
  "license": "MIT",
  "activationEvents": [
    "onStartup"
  ],
  "main": "main.js",
  "contributes": {
    "commands": [
      {
        "id": "requestForge.sendRequest",
        "title": "Request Forge: Send Request",
        "category": "Request Forge",
        "icon": "play"
      },
      {
        "id": "requestForge.newRequestFile",
        "title": "Request Forge: New Request File (.http)",
        "category": "Request Forge",
        "icon": "new-file"
      },
      {
        "id": "requestForge.manageEnvs",
        "title": "Request Forge: Manage Environments",
        "category": "Request Forge",
        "icon": "settings-gear"
      },
      {
        "id": "requestForge.switchEnv",
        "title": "Request Forge: Switch Environment",
        "category": "Request Forge"
      },
      {
        "id": "requestForge.clearHistory",
        "title": "Request Forge: Clear Request History",
        "category": "Request Forge"
      },
      {
        "id": "requestForge.copyResponse",
        "title": "Request Forge: Copy Response Body",
        "category": "Request Forge"
      },
      {
        "id": "requestForge.saveResponse",
        "title": "Request Forge: Save Response to File",
        "category": "Request Forge"
      },
      {
        "id": "requestForge.cancelRequest",
        "title": "Request Forge: Cancel Request",
        "category": "Request Forge",
        "icon": "stop"
      }
    ],
    "views": [
      {
        "id": "requestForge.panel",
        "name": "Request Forge",
        "icon": "$(globe)"
      }
    ],
    "languages": [
      {
        "id": "http",
        "aliases": [
          "HTTP",
          "Rest"
        ],
        "extensions": [
          ".http",
          ".rest"
        ]
      }
    ],
    "keybindings": [
      {
        "command": "requestForge.sendRequest",
        "key": "ctrl+alt+r",
        "when": "editorTextFocus"
      },
      {
        "command": "requestForge.newRequestFile",
        "key": "ctrl+alt+shift+r",
        "when": ""
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "requestForge.sendRequest",
          "group": "0_run",
          "when": "editorTextFocus"
        },
        {
          "command": "requestForge.copyResponse",
          "group": "0_run"
        }
      ],
      "editor/title": [
        {
          "command": "requestForge.sendRequest",
          "group": "navigation",
          "when": "editorLangId == http"
        }
      ],
      "commandPalette": [
        {
          "command": "requestForge.sendRequest"
        },
        {
          "command": "requestForge.newRequestFile"
        },
        {
          "command": "requestForge.manageEnvs"
        },
        {
          "command": "requestForge.switchEnv"
        },
        {
          "command": "requestForge.clearHistory"
        },
        {
          "command": "requestForge.copyResponse"
        },
        {
          "command": "requestForge.saveResponse"
        }
      ]
    },
    "statusBarItems": [
      {
        "id": "requestForge.status",
        "text": "$(globe) Request Forge",
        "tooltip": "Request Forge — Ctrl+Alt+R para enviar",
        "command": "requestForge.switchEnv",
        "alignment": "right",
        "priority": 25
      }
    ],
    "settingsTabs": [
      {
        "id": "request-forge.settings",
        "label": "Request Forge",
        "icon": "globe"
      }
    ],
    "configuration": {
      "title": "Request Forge",
      "properties": {
        "requestForge.timeout": {
          "type": "number",
          "default": 30000,
          "description": "Timeout das requisições em ms (padrão: 30000)"
        },
        "requestForge.followRedirects": {
          "type": "boolean",
          "default": true,
          "description": "Seguir redirecionamentos automaticamente"
        },
        "requestForge.prettifyResponse": {
          "type": "boolean",
          "default": true,
          "description": "Formatar JSON/XML na resposta automaticamente"
        },
        "requestForge.saveHistory": {
          "type": "boolean",
          "default": true,
          "description": "Salvar histórico de requisições"
        },
        "requestForge.maxHistoryItems": {
          "type": "number",
          "default": 100,
          "description": "Máximo de requisições no histórico"
        },
        "requestForge.defaultEnvironment": {
          "type": "string",
          "default": "",
          "description": "Ambiente padrão ativo (nome)"
        }
      }
    }
  }
}
