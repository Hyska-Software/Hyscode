  },

  "Ecto Query": {
    "prefix": ["query", "ecto-query"],
    "body": [
      "import Ecto.Query",
      "",
      "from(${1:s} in ${2:MyApp.Schema},",
      "  where: ${1:s}.${3:field} == ^${4:value},",
      "  select: ${1:s}",
      ")"
    ],
    "description": "Ecto Query DSL"
  },

  "Phoenix Controller": {
    "prefix": ["controller", "phx-controller"],
    "body": [
      "defmodule ${1:MyAppWeb}.${2:Resource}Controller do",
      "  use ${1:MyAppWeb}, :controller",
      "",
      "  alias ${3:MyApp.Context}",
      "",
      "  def index(conn, _params) do",
      "    items = ${3:Context}.list_${4:items}()",
      "    render(conn, :index, ${4:items}: items)",
      "  end",
      "",
      "  def show(conn, %{\"id\" => id}) do",
      "    item = ${3:Context}.get_${5:item}!(id)",
      "    render(conn, :show, ${5:item}: item)",
      "  end",
      "",
      "  def create(conn, %{\"${5:item}\" => ${5:item}_params}) do",
      "    case ${3:Context}.create_${5:item}(${5:item}_params) do",
      "      {:ok, ${5:item}} ->",
      "        conn",
      "        |> put_flash(:info, \"${2:Resource} criado com sucesso.\")",
      "        |> redirect(to: ~p\"/${4:items}/#{${5:item}}\")",
      "",
      "      {:error, %Ecto.Changeset{} = changeset} ->",
      "        render(conn, :new, changeset: changeset)",
      "    end",
      "  end",
      "",
      "  $0",
      "end"
    ],
    "description": "Phoenix Controller com CRUD básico"
  },

  "Phoenix LiveView": {
    "prefix": ["liveview", "phx-liveview"],
    "body": [
      "defmodule ${1:MyAppWeb}.${2:Resource}Live do",
      "  use ${1:MyAppWeb}, :live_view",
      "",
      "  @impl true",
      "  def mount(_params, _session, socket) do",
      "    {:ok, assign(socket, ${3:key}: ${4:value})}",
      "  end",
      "",
      "  @impl true",
      "  def handle_params(params, _url, socket) do",
      "    {:noreply, $0}",
      "  end",
      "",
      "  @impl true",
      "  def handle_event(\"${5:event}\", params, socket) do",
      "    {:noreply, socket}",
      "  end",
      "",
      "  @impl true",
      "  def render(assigns) do",
      "    ~H\"\"\"",
      "    <div>",
      "      ${6:<!-- conteúdo -->}",
      "    </div>",
