  "Ecto Schema": {
    "prefix": ["schema", "ecto-schema"],
    "body": [
      "defmodule ${1:MyApp.Schema} do",
      "  use Ecto.Schema",
      "  import Ecto.Changeset",
      "",
      "  @primary_key {:id, :binary_id, autogenerate: true}",
      "  @foreign_key_type :binary_id",
      "",
      "  schema \"${2:table_name}\" do",
      "    field :${3:name}, :${4|string,integer,boolean,float,map,array|}",
      "",
      "    timestamps(type: :utc_datetime_usec)",
      "  end",
      "",
      "  @doc false",
      "  def changeset(schema, attrs) do",
      "    schema",
      "    |> cast(attrs, [${5::name}])",
      "    |> validate_required([${5::name}])",
      "    $0",
      "  end",
      "end"
    ],
    "description": "Ecto Schema com changeset"
  },

  "Ecto changeset": {
    "prefix": ["changeset"],
    "body": [
      "def changeset(${1:schema}, attrs) do",
      "  ${1:schema}",
      "  |> cast(attrs, [${2::field}])",
      "  |> validate_required([${2::field}])",
      "  $0",
      "end"
    ],
    "description": "Ecto changeset function"
  },

  "Ecto belongs_to": {
