  "Phoenix Context": {
    "prefix": ["context", "phx-context"],
    "body": [
      "defmodule ${1:MyApp}.${2:Context} do",
      "  @moduledoc \"\"\"",
      "  The ${2:Context} context.",
      "  \"\"\"",
      "",
      "  import Ecto.Query, warn: false",
      "  alias ${1:MyApp}.Repo",
      "  alias ${1:MyApp}.${2:Context}.${3:Schema}",
      "",
      "  def list_${4:schemas} do",
      "    Repo.all(${3:Schema})",
      "  end",
      "",
      "  def get_${5:schema}!(id), do: Repo.get!(${3:Schema}, id)",
      "",
      "  def create_${5:schema}(attrs \\\\ %{}) do",
      "    %${3:Schema}{}",
      "    |> ${3:Schema}.changeset(attrs)",
      "    |> Repo.insert()",
      "  end",
      "",
      "  def update_${5:schema}(%${3:Schema}{} = ${5:schema}, attrs) do",
      "    ${5:schema}",
      "    |> ${3:Schema}.changeset(attrs)",
      "    |> Repo.update()",
      "  end",
      "",
      "  def delete_${5:schema}(%${3:Schema}{} = ${5:schema}) do",
      "    Repo.delete(${5:schema})",
      "  end",
      "",
      "  def change_${5:schema}(%${3:Schema}{} = ${5:schema}, attrs \\\\ %{}) do",
      "    ${3:Schema}.changeset(${5:schema}, attrs)",
      "  end",
      "end"
    ],
    "description": "Phoenix Context com CRUD completo"
  },

