  "case": {
    "prefix": ["case"],
    "body": [
      "case ${1:expression} do",
      "  ${2::ok} ->",
      "    ${3::handled}",
      "",
      "  {:error, reason} ->",
      "    ${0:{:error, reason}}",
      "end"
    ],
    "description": "case/do/end"
  },

  "cond": {
    "prefix": ["cond"],
    "body": [
      "cond do",
      "  ${1:condition1} ->",
      "    ${2::result1}",
      "",
      "  ${3:condition2} ->",
      "    ${4::result2}",
      "",
      "  true ->",
      "    ${0::default}",
      "end"
    ],
    "description": "cond/do/end"
  },

  "with": {
    "prefix": ["with"],
    "body": [
      "with {:ok, ${1:result1}} <- ${2:step1()},",
      "     {:ok, ${3:result2}} <- ${4:step2()} do",
      "  {:ok, $0}",
      "else",
      "  {:error, reason} -> {:error, reason}",
      "end"
    ],
    "description": "with/do/else/end"
  },

  "fn": {
    "prefix": ["fn"],
    "body": [
      "fn ${1:arg} -> ${0:body} end"
    ],
    "description": "Função anônima inline"
  },

  "fn block": {
    "prefix": ["fnb", "fn-block"],
    "body": [
