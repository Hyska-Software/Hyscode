      "  $0",
      "end"
    ],
    "description": "Função privada"
  },

  "defmacro": {
    "prefix": ["defmacro"],
    "body": [
      "defmacro ${1:macro_name}(${2:args}) do",
      "  quote do",
      "    $0",
      "  end",
      "end"
    ],
    "description": "Macro pública"
  },

  "def guard": {
    "prefix": ["defguard"],
    "body": [
