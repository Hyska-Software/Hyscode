      "  @enforce_keys [${2::id}]",
      "  defstruct [",
      "    :${2:id},",
      "    ${3::name},",
      "    ${0}",
      "  ]",
      "",
      "  @type t :: %__MODULE__{",
      "    ${2:id}: ${4:integer()},",
      "    ${3:name}: ${5:String.t()}",
      "  }",
      "end"
    ],
    "description": "defstruct com @type"
  },

