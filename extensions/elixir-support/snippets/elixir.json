{
  "defmodule": {
    "prefix": ["defmodule", "mod"],
    "body": [
      "defmodule ${1:MyApp.ModuleName} do",
      "  @moduledoc \"\"\"",
      "  ${2:Documentação do módulo.}",
      "  \"\"\"",
      "",
      "  $0",
      "end"
    ],
    "description": "Declaração de módulo Elixir"
  },

  "defmodule GenServer": {
    "prefix": ["genserver", "defmodule-genserver"],
    "body": [
      "defmodule ${1:MyApp.Worker} do",
      "  @moduledoc \"\"\"",
      "  ${2:GenServer worker.}",
      "  \"\"\"",
      "  use GenServer",
      "",
      "  # ─── Client API ───────────────────────────────────────────────────────",
      "",
      "  def start_link(opts \\\\ []) do",
      "    GenServer.start_link(__MODULE__, opts, name: __MODULE__)",
      "  end",
      "",
      "  def ${3:action}(${4:arg}) do",
      "    GenServer.call(__MODULE__, {${5::action}, ${4:arg}})",
      "  end",
      "",
      "  # ─── Server Callbacks ─────────────────────────────────────────────────",
      "",
      "  @impl true",
      "  def init(opts) do",
      "    {:ok, %{$0}}",
      "  end",
      "",
      "  @impl true",
      "  def handle_call({${5::action}, ${4:arg}}, _from, state) do",
      "    {:reply, :ok, state}",
      "  end",
      "",
      "  @impl true",
      "  def handle_cast(_msg, state) do",
      "    {:noreply, state}",
      "  end",
      "",
      "  @impl true",
      "  def handle_info(_msg, state) do",
      "    {:noreply, state}",
      "  end",
      "end"
    ],
    "description": "Módulo GenServer completo"
  },

  "defmodule Supervisor": {
    "prefix": ["supervisor", "defmodule-supervisor"],
    "body": [
      "defmodule ${1:MyApp.Supervisor} do",
      "  use Supervisor",
      "",
      "  def start_link(init_arg) do",
      "    Supervisor.start_link(__MODULE__, init_arg, name: __MODULE__)",
      "  end",
      "",
      "  @impl true",
      "  def init(_init_arg) do",
      "    children = [",
      "      ${0:# {MyApp.Worker, []}}",
      "    ]",
      "",
      "    Supervisor.init(children, strategy: :one_for_one)",
      "  end",
      "end"
    ],
    "description": "Módulo Supervisor"
  },

  "defmodule Agent": {
    "prefix": ["agent", "defmodule-agent"],
    "body": [
      "defmodule ${1:MyApp.Store} do",
      "  use Agent",
      "",
      "  def start_link(initial_value) do",
      "    Agent.start_link(fn -> initial_value end, name: __MODULE__)",
      "  end",
      "",
      "  def get do",
      "    Agent.get(__MODULE__, & &1)",
      "  end",
      "",
      "  def update(new_value) do",
      "    Agent.update(__MODULE__, fn _state -> new_value end)",
      "  end",
      "end"
    ],
    "description": "Módulo Agent"
  },

  "defmodule Task": {
    "prefix": ["task-module"],
    "body": [
      "Task.async(fn ->",
      "  $0",
      "end)",
      "|> Task.await()"
    ],
    "description": "Task.async com Task.await"
  },

  "def": {
    "prefix": ["def", "defn"],
    "body": [
      "def ${1:function_name}(${2:args}) do",
      "  $0",
      "end"
    ],
    "description": "Função pública"
  },

  "defp": {
    "prefix": ["defp", "defpn"],
    "body": [
