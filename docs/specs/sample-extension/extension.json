{
  "name": "sample-extension",
  "displayName": "Sample Extension",
  "version": "1.0.0",
  "description": "A sample HysCode extension demonstrating all contribution points",
  "publisher": "hyscode",
  "engines": { "hyscode": ">=0.1.0" },
  "categories": ["Other"],
  "keywords": ["sample", "demo", "template"],
  "main": "main.js",
  "activationEvents": [
    "onCommand:sample.helloWorld",
    "onCommand:sample.listarArquivos"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sample.helloWorld",
        "title": "Hello World",
        "category": "Sample"
      },
      {
        "command": "sample.listarArquivos",
        "title": "Listar Arquivos",
        "category": "Sample"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "sample.helloWorld" },
        { "command": "sample.listarArquivos" }
      ]
    },
    "keybindings": [
      {
        "command": "sample.helloWorld",
        "key": "ctrl+shift+h"
      }
    ],
    "configuration": {
      "title": "Sample Extension",
      "properties": {
        "sample.greeting": {
          "type": "string",
          "default": "Hello from Sample Extension!",
          "description": "The greeting message to show"
        }
      }
    }
  }
}
